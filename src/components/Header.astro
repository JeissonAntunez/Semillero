
---
import '../styles/global.css';
---


<div class="relative h-screen w-full bg-[url('/Banner.jpg')] bg-cover bg-center flex flex-col text-white font-sans">
    
  
    <div class="absolute inset-0 bg-black/50"></div>

  
    <div class="relative z-10 flex flex-col h-full">
        
       
        <nav class="flex items-center justify-between px-10 py-6">
            <div class="flex items-center gap-2">
                
                <div class="w-10 h-10 bg-orange-500 rounded-full flex items-center justify-center font-bold text-xs">LOGO</div>
                <h2 class="text-xl font-bold tracking-tight">Academia Tenis</h2>
            </div>
            
            <ul class="hidden md:flex gap-6 text-sm font-medium text-gray-200">
                <li><a href="#" class="hover:text-white">Sobre Nosotros</a></li>
                <li><a href="#" class="hover:text-white">Horarios</a></li>
                <li><a href="#" class="hover:text-white">Eventos</a></li>
                <li><a href="#" class="hover:text-white">Galería</a></li>
                <li><a href="#" class="hover:text-white">Contacto</a></li>
                <li><a href="#" class="hover:text-white">Tienda</a></li>
            </ul>

            <button class="bg-orange-600 hover:bg-orange-700 px-6 py-2 rounded-full text-sm font-semibold transition">
                Inscríbete
            </button>
        </nav>

       
        <div class="flex-grow flex flex-col items-center justify-center text-center px-4 max-w-4xl mx-auto">
            <span class="bg-orange-500/80 text-[10px] tracking-widest px-3 py-1 rounded-full mb-6 uppercase font-bold">
                El deporte más completo del mundo
            </span>

            <h1 class="text-5xl md:text-7xl font-bold mb-8 leading-tight">
                El Deporte Supremo <br> para la <span class="underline decoration-white underline-offset-8">Longevidad</span>
            </h1>

            <div class="flex gap-4 mb-10">
                <button class="bg-orange-800/80 hover:bg-orange-900 border border-orange-400/30 px-8 py-3 rounded-full flex items-center gap-2 font-semibold transition">
                    Reservar 👤
                </button>
                <button class="bg-orange-800/80 hover:bg-orange-900 border border-orange-400/30 px-8 py-3 rounded-full flex items-center gap-2 font-semibold transition">
                    Tienda 🛒
                </button>
            </div>

            <p class="text-lg md:text-xl text-gray-200 leading-relaxed max-w-2xl">
                Vive más, siéntete mejor y domina tu juego. Aumenta tu esperanza de vida hasta 
                <span class="font-bold text-white">9.7 años</span> mientras mejoras tu salud cardiovascular, 
                enfoque mental y acondicionamiento físico total.
            </p>
        </div>
    </div>
</div>
