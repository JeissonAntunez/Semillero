---
// Datos de tus sedes (puedes añadir más aquí)
const sedes = [
  {
    id: "A",
    nombre: "Sede Los Olivos",
    coords: { lat: -11.961, lng: -77.068 },
    direccion: "San Manuel 137, Los Olivos",
    distrito: "Los Olivos, Lima"
  },
  {
    id: "B",
    nombre: "Sede Villasol",
    coords: { lat: -11.955, lng: -77.075 },
    direccion: "Parque Medalla Milagrosa",
    distrito: "Los Olivos, Lima"
  }
];
---

<section class="max-w-7xl mx-auto py-12 px-4 font-sans">
  <h2 class="text-3xl font-bold text-stone-800 mb-8 italic uppercase tracking-tighter">Nuestras Sedes</h2>

  <div class="flex flex-col gap-6">
    <!-- Contenedor de Tarjetas Estilo "Commutes" -->
    <div class="flex overflow-x-auto pb-4 gap-4 custom-scrollbar" id="destinations-list">
      {sedes.map((sede, index) => (
        <button 
          class:list={[
            "sede-card min-w-[280px] flex-1 bg-white p-4 rounded-xl shadow-md border-t-4 transition-all text-left relative group",
            index === 0 ? "border-blue-500 active-sede" : "border-transparent"
          ]}
          data-lat={sede.coords.lat}
          data-lng={sede.coords.lng}
        >
          <div class="flex items-center gap-2 mb-2">
            <span class="location-marker bg-stone-100 text-stone-600 font-bold px-2 py-0.5 rounded text-sm group-[.active-sede]:bg-red-100 group-[.active-sede]:text-red-600">
              {sede.id}
            </span>
            <span class="text-xs font-bold text-stone-400 uppercase tracking-widest">Sede Oficial</span>
          </div>
          
          <h3 class="text-lg font-black text-stone-800 leading-tight uppercase italic">{sede.nombre}</h3>
          <p class="text-sm text-stone-500 truncate mt-1">{sede.direccion}</p>
          <p class="text-xs text-stone-400">{sede.distrito}</p>

          <!-- Botón flotante estilo Google -->
          <div class="absolute right-4 top-1/2 -translate-y-1/2">
             <div class="w-10 h-10 rounded-full border border-stone-200 flex items-center justify-center bg-white group-[.active-sede]:text-blue-500 group-[.active-sede]:border-blue-200 shadow-sm">
                
             </div>
          </div>
        </button>
      ))}
    </div>

    <!-- Mapa Interactivo -->
    <div id="map" class="w-full h-[450px] rounded-2xl shadow-inner bg-stone-100 border border-stone-200"></div>
  </div>
</section>

<style>
    @reference "tailwindcss"; 
  .custom-scrollbar::-webkit-scrollbar { height: 6px; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
  
  .active-sede { 
    /* Ahora ya no marcará error */
    @apply ring-2 ring-blue-100 shadow-lg; 
  }
</style>

<script>
  import { Loader } from "@googlemaps/js-api-loader";

  const loader = new Loader({
    apiKey: "AIzaSyBFu9g2TiBtz1AQ4mAjoTWbnGaZywVo4WA", // REEMPLAZA CON TU API KEY
    version: "weekly"
  });

  async function initMap() {
    const mapElement = document.getElementById("map") as HTMLElement;
    if (!mapElement) return;

    try {
      // Cargamos librerías con el nuevo estándar funcional
      const [{ Map }, { AdvancedMarkerElement, PinElement }] = await Promise.all([
        (loader as any).importLibrary("maps"),
        (loader as any).importLibrary("marker")
      ]) as [google.maps.MapsLibrary, google.maps.MarkerLibrary];

      const map = new Map(mapElement, {
        center: { lat: -11.958, lng: -77.071 },
        zoom: 14,
        mapId: "DEMO_MAP_ID", // Cambia por tu MapID real para estilos
        disableDefaultUI: false,
      });

      const buttons = document.querySelectorAll('.sede-card') as NodeListOf<HTMLButtonElement>;

      buttons.forEach((button) => {
        const lat = parseFloat(button.dataset.lat || "0");
        const lng = parseFloat(button.dataset.lng || "0");

        // Pin personalizado
        const pin = new PinElement({
          background: "#3b82f6",
          borderColor: "#fff",
          glyphColor: "#fff",
        });

        new AdvancedMarkerElement({
          map,
          position: { lat, lng },
          content: pin.element,
        });

        button.addEventListener('click', () => {
          map.panTo({ lat, lng });
          setTimeout(() => map.setZoom(17), 300);

          // Actualizar UI de tarjetas
          buttons.forEach(b => {
            b.classList.remove('border-blue-500', 'active-sede');
            b.classList.add('border-transparent');
          });
          button.classList.add('border-blue-500', 'active-sede');
          button.classList.remove('border-transparent');
        });
      });
    } catch (e) {
      console.error(e);
    }
  }

  initMap();
</script>
