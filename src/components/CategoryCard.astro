---
// CategoryCard.astro
interface Props {
  title: string;
  description: string;
  image: string;
}

const { title, description, image } = Astro.props;
---

<div class="relative overflow-hidden rounded-2xl group h-64 shadow-lg">
  <!-- Imagen de fondo con overlay -->
  <img 
    src={image} 
    alt={title} 
    class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
  />
  <div class="absolute inset-0 bg-black/50 group-hover:bg-black/40 transition-colors"></div>

  <!-- Contenido -->
  <div class="relative h-full flex flex-col justify-center items-center text-center p-6">
    <h3 class="text-orange-500 font-bold text-2xl mb-2">{title}</h3>
    <p class="text-white text-sm leading-relaxed">
      {description}
    </p>
  </div>
</div>
