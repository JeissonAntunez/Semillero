---
// Puedes importar tus imágenes aquí
const imagenes = [
  "/img1.jpg", "/img2.jpg", "/img3.jpg", "/img4.jpg", "/img5.jpg", "/img6.jpg"
];
---

<section class="text-center py-10">
  <h2 class="text-2xl font-semibold text-stone-700 mb-4">Galeria Superficie</h2>
  
  <!-- Pelotas de Colores (Botones) -->
  <div class="flex justify-center gap-4 mb-8">
    <button 
      data-color="bg-[#B36B4D]" 
      class="color-btn w-8 h-8 rounded-full bg-[#B36B4D] hover:scale-110 transition-transform shadow-md" 
      aria-label="Marrón"></button>
    <button 
      data-color="bg-[#2D70A4]" 
      class="color-btn w-8 h-8 rounded-full bg-[#2D70A4] hover:scale-110 transition-transform shadow-md" 
      aria-label="Azul"></button>
    <button 
      data-color="bg-[#8E9E49]" 
      class="color-btn w-8 h-8 rounded-full bg-[#8E9E49] hover:scale-110 transition-transform shadow-md" 
      aria-label="Verde"></button>
  </div>

  <!-- Contenedor de la Galería -->
  <div id="gallery-container" class="bg-[#B36B4D] p-6 transition-colors duration-500 ease-in-out mx-auto max-w-5xl rounded-sm">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-2 h-[500px]">
      
      <!-- Columna 1 (Imagen larga) -->
      <div class="md:col-span-1 h-full">
        <img src={imagenes[0]} class="w-full h-full object-cover border-4 border-white" />
      </div>

      <!-- Columna 2 (Dos imágenes cuadradas) -->
      <div class="md:col-span-1 flex flex-col gap-2 h-full">
        <img src={imagenes[1]} class="w-full h-1/2 object-cover border-4 border-white" />
        <img src={imagenes[2]} class="w-full h-1/2 object-cover border-4 border-white" />
      </div>

      <!-- Columna 3 (Dos imágenes cuadradas) -->
      <div class="md:col-span-1 flex flex-col gap-2 h-full">
        <img src={imagenes[3]} class="w-full h-1/2 object-cover border-4 border-white" />
        <img src={imagenes[4]} class="w-full h-1/2 object-cover border-4 border-white" />
      </div>

      <!-- Columna 4 (Imagen larga) -->
      <div class="md:col-span-1 h-full">
        <img src={imagenes[5]} class="w-full h-full object-cover border-4 border-white" />
      </div>

    </div>
  </div>
</section>

<script>
  // Lógica para cambiar el color
  const buttons = document.querySelectorAll('.color-btn');
  const container = document.getElementById('gallery-container');

  buttons.forEach(button => {
    button.addEventListener('click', () => {
      const newColor = button.getAttribute('data-color');
      
      // Removemos cualquier clase de fondo previa (bg-...)
      const currentClasses = container.className.split(' ');
      const filteredClasses = currentClasses.filter(c => !c.startsWith('bg-['));
      
      // Aplicamos la nueva clase y mantenemos las demás
      container.className = [...filteredClasses, newColor].join(' ');
    });
  });
</script>
