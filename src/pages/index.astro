---


import Header from '../components/Header.astro';
import Galeria from '../components/Galeria.astro';
import MagneticSponsors from '../components/MagneticSponsors.astro';
import Sedes from '../components/Sedes.astro';
import SedesInteractivas from '../components/SedesInteractivas.astro';
import Footer from '../components/Footer.astro';
import CategoryCard from '../components/CategoryCard.astro';

import Layout from '../layouts/Layout.astro';

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.


const dato = ["Lunes", "Martes", "Miercoles", "Jueves", "Viernes", "Sabado", "Domingo"];

const categories = [
  {
	title: "Baby Tenis",
	description: "Inicia tu aventura en el tenis con nuestros programas especializados para tus pequeños.",
	image: "/BabyTenis.jpg"
  },
  {
	title: "Mini Tenis",
	description: "Desarrolla tus habilidades en el tenis con nuestros programas para niños.",
	image: "/MiniTenis.jpg"
  },
  {
	title: "Juvenil",
	description: "Aprende y mejora tus habilidades en el tenis con nuestros programas para jóvenes.",
	image: "TenisJuvenil.jpg"
  },
  {
	title: "Adulto Libre",
	description: "Continúa tu desarrollo en el tenis con nuestros programas para adultos.",
	image: "AdultoLibre.jpg"
  }
];
---

<Layout title="Welcome to Astro!">
	<main >
		<Header />

<section class="max-w-6xl mx-auto py-12 px-4 font-sans">
  <h2 class="text-center text-4xl font-bold text-stone-700 mb-10">Nuestras Categorías</h2>
  
  <!-- Grid de Categorías -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
    {categories.map((cat) => (
      <CategoryCard {...cat} />
    ))}
  </div>

  <!-- Sección de Estadísticas -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center border-t pt-10 border-stone-200">
    <div>
      <p class="text-5xl font-black text-stone-800 italic">5</p>
      <p class="text-stone-500 uppercase tracking-widest text-sm font-semibold mt-2">Años de experiencia</p>
    </div>
    <div>
      <p class="text-5xl font-black text-stone-800 italic">100+</p>
      <p class="text-stone-500 uppercase tracking-widest text-sm font-semibold mt-2">Alumnos</p>
    </div>
    <div>
      <p class="text-5xl font-black text-stone-800 italic">2</p>
      <p class="text-stone-500 uppercase tracking-widest text-sm font-semibold mt-2">Sedes</p>
    </div>
  </div>
</section>
<Galeria />
		<MagneticSponsors />
		<!-- <Sedes /> -->
		<SedesInteractivas />
	</main>
  <Footer />
	
</Layout>
